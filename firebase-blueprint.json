{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and balance information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "balance": { "type": "number" },
        "totalSpent": { "type": "number" },
        "totalOrders": { "type": "number" },
        "supportPin": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role", "balance"]
    },
    "Product": {
      "title": "Product",
      "description": "Game top-up or voucher product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "packages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "originalPrice": { "type": "number" }
            }
          }
        },
        "rules": { "type": "array", "items": { "type": "string" } },
        "isActive": { "type": "boolean" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Game top-up order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "packageId": { "type": "string" },
        "packageName": { "type": "string" },
        "playerID": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Voucher": {
      "title": "Voucher",
      "description": "Gift voucher/code order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "packageName": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "codes": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Banner": {
      "title": "Banner",
      "description": "Home page slider banner",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "image": { "type": "string" },
        "link": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Wallet add money transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/products/{productId}": { "schema": "Product", "description": "Game products" },
    "/orders/{orderId}": { "schema": "Order", "description": "Top-up orders" },
    "/vouchers/{voucherId}": { "schema": "Voucher", "description": "Voucher orders" },
    "/banners/{bannerId}": { "schema": "Banner", "description": "Home banners" },
    "/transactions/{transactionId}": { "schema": "Transaction", "description": "Wallet transactions" }
  }
}
